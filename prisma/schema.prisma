generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskType {
  DISASTER
  HIGH_RISK_AREA
}

enum PushPlatform {
  ANDROID
}

enum GuardianRelationshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                String                 @id @default(uuid())
  email             String                 @unique
  phoneNumber       String                 @unique
  deviceId          String                 @unique
  passwordHash      String
  refreshTokenHash  String?
  outboxEvents      UserEventOutbox[]
  location          UserLocation?
  locationEvents    UserLocationEvent[]
  risks             UserRisk[]
  riskEvents        UserRiskEvent[]
  riskNotifications UserRiskNotification[]
  asGuardian        GuardianRelationship[] @relation("Guardian")
  asGuardee         GuardianRelationship[] @relation("Guardee")
  pushDevices       PushDevice[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model PushDevice {
  id                     String       @id @default(uuid())
  userId                 String
  firebaseInstallationId String       @unique
  platform               PushPlatform
  enabled                Boolean      @default(true)
  lastSeenAt             DateTime     @default(now())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  user                   User         @relation(fields: [userId], references: [id])

  @@index([userId, enabled])
}

model GuardianRelationship {
  id          String                     @id @default(uuid())
  guardianId  String
  guardeeId   String
  status      GuardianRelationshipStatus @default(PENDING)
  requestedAt DateTime                   @default(now())
  respondedAt DateTime?
  updatedAt   DateTime                   @updatedAt
  guardian    User                       @relation("Guardian", fields: [guardianId], references: [id])
  guardee     User                       @relation("Guardee", fields: [guardeeId], references: [id])

  @@unique([guardianId, guardeeId])
  @@index([guardianId, status])
  @@index([guardeeId, status])
}

model UserEventOutbox {
  id          String    @id @default(uuid())
  userId      String
  sequence    Int
  eventType   String
  payload     Json
  createdAt   DateTime  @default(now())
  publishedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, sequence])
  @@index([publishedAt, createdAt])
}

model ProcessedUserEvent {
  consumerGroup String
  userId        String
  sequence      Int
  eventId       String
  processedAt   DateTime @default(now())

  @@id([consumerGroup, userId])
  @@unique([consumerGroup, eventId])
}

model UserLocation {
  userId    String   @id
  latitude  Decimal  @db.Decimal(9, 6)
  longitude Decimal  @db.Decimal(9, 6)
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model UserLocationEvent {
  id         String   @id @default(uuid())
  userId     String
  latitude   Decimal  @db.Decimal(9, 6)
  longitude  Decimal  @db.Decimal(9, 6)
  detectedAt DateTime
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, detectedAt])
}

model UserRisk {
  userId    String
  riskType  RiskType
  riskLevel RiskLevel
  updatedAt DateTime
  user      User      @relation(fields: [userId], references: [id])

  @@id([userId, riskType])
}

model UserRiskEvent {
  id         String    @id @default(uuid())
  userId     String
  riskType   RiskType
  riskLevel  RiskLevel
  detectedAt DateTime
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, riskType, detectedAt])
}

model UserRiskNotification {
  userId   String
  riskType RiskType
  sentAt   DateTime
  user     User     @relation(fields: [userId], references: [id])

  @@id([userId, riskType])
}
