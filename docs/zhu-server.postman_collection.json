{
  "info": {
    "name": "zhu-server",
    "description": "Postman collection for the zhu-server NestJS API. The server is mounted under the global /api prefix (see src/main.ts), so all paths below include it via the {{baseUrl}} variable (default: http://localhost:3000/api).\n\nRun the requests in this order to keep collection variables in sync:\n  1. App > Get status\n  2. Auth > Register (populates {{accessToken}} and {{refreshToken}})\n  3. Auth > Login (refreshes the tokens)\n  4. Auth > Me (uses {{accessToken}})\n  5. Locations > Update location (uses {{accessToken}})\n  6. User risks > Set liveness check (uses {{accessToken}})\n  7. User risks > Get liveness check statuses (uses {{accessToken}})\n  8. User risks > Respond to liveness check (uses {{accessToken}})\n  9. Auth > Refresh (uses {{refreshToken}})\n  10. Auth > Logout (uses {{accessToken}})",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "guardianPhoneNumber",
      "value": "",
      "type": "string"
    },
    {
      "key": "guardianId",
      "value": "",
      "type": "string"
    },
    {
      "key": "guardeeId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "Get status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Health check. Returns { status: 'ok' } (AppController.getStatus)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response includes status field', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Test User\",\n  \"email\": \"test+user@example.com\",\n  \"password\": \"Password123\",\n  \"phoneNumber\": \"+628123456789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "POST /api/auth/register. Body: RegisterDto { displayName (optional, max 80 chars), email, password (min 8 chars), phoneNumber (E.164) }. Returns { accessToken, refreshToken }. Throws 409 on duplicate email or phone number."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains accessToken and refreshToken', function () {",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json).to.have.property('refreshToken');",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test+user@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "POST /api/auth/login (returns 200). Body: LoginDto { email, password (min 8 chars) }. Returns { accessToken, refreshToken }. Throws 401 on invalid credentials."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains accessToken and refreshToken', function () {",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json).to.have.property('refreshToken');",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "POST /api/auth/refresh (returns 200). Body: { refreshToken }. Returns { accessToken, refreshToken } and rotates the stored refresh token. Throws 401 on invalid/expired refresh token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains accessToken and refreshToken', function () {",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json).to.have.property('refreshToken');",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isOkay\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "POST /api/auth/logout. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Invalidates the current session for the JWT's sub. No request body."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "GET /api/auth/me. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Returns the JwtPayload { sub, email }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response has sub and email', function () {",
                  "  pm.expect(json).to.have.property('sub');",
                  "  pm.expect(json).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Guardians",
      "item": [
        {
          "name": "Request Guardian",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{guardianPhoneNumber}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/guardians/requests",
              "host": ["{{baseUrl}}"],
              "path": ["guardians", "requests"]
            },
            "description": "POST /api/guardians/requests. Requires Authorization: Bearer {{accessToken}}. Requests that the registered user with {{guardianPhoneNumber}} becomes the authenticated user's guardian."
          }
        },
        {
          "name": "List Guardians",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardians",
              "host": ["{{baseUrl}}"],
              "path": ["guardians"]
            },
            "description": "GET /api/guardians. Requires Authorization: Bearer {{accessToken}}. Lists the authenticated user's guardian requests and accepted guardians."
          }
        },
        {
          "name": "Remove Guardian",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardians/{{guardianId}}",
              "host": ["{{baseUrl}}"],
              "path": ["guardians", "{{guardianId}}"]
            },
            "description": "DELETE /api/guardians/:guardianId. Requires Authorization: Bearer {{accessToken}}. Removes the selected guardian relationship."
          }
        }
      ]
    },
    {
      "name": "Guardian Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardian-notifications?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["guardian-notifications"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "GET /api/guardian-notifications. Requires a guardian access token. Returns newest-first notification history with guardee id, nullable displayName, email, riskType, trigger, and sentAt. Use nextCursor as the cursor query parameter for the next page."
          }
        }
      ]
    },
    {
      "name": "Guardees",
      "item": [
        {
          "name": "List Pending Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardees/requests",
              "host": ["{{baseUrl}}"],
              "path": ["guardees", "requests"]
            },
            "description": "GET /api/guardees/requests. Requires the prospective guardian's access token. Lists pending guardian requests."
          }
        },
        {
          "name": "Accept Guardee Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/guardees/requests/{{guardeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["guardees", "requests", "{{guardeeId}}"]
            },
            "description": "PATCH /api/guardees/requests/:guardeeId. Requires the prospective guardian's access token. Use ACCEPTED or DECLINED."
          }
        },
        {
          "name": "List Guardees",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardees",
              "host": ["{{baseUrl}}"],
              "path": ["guardees"]
            },
            "description": "GET /api/guardees. Requires Authorization: Bearer {{accessToken}}. Lists accepted guardees."
          }
        },
        {
          "name": "Get Guardee Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardees/{{guardeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["guardees", "{{guardeeId}}"]
            },
            "description": "GET /api/guardees/:guardeeId. Requires an accepted guardian relationship. Returns the guardee and current location; safety ping details are not implemented yet."
          }
        },
        {
          "name": "Remove Guardee",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guardees/{{guardeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["guardees", "{{guardeeId}}"]
            },
            "description": "DELETE /api/guardees/:guardeeId. Requires Authorization: Bearer {{accessToken}}. Removes an accepted guardian relationship."
          }
        }
      ]
    },
    {
      "name": "Locations",
      "item": [
        {
          "name": "Update location",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": -10.0,\n  \"longitude\": -20.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/locations",
              "host": ["{{baseUrl}}"],
              "path": ["locations"]
            },
            "description": "POST /api/locations. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Body: UpdateLocationDto { latitude, longitude }. Upserts the user's latest location in UserLocation and appends a history event to UserLocationEvent in a single transaction, then writes a UserEventOutbox row for Kafka dispatch. Risk evaluation: both latitude and longitude negative -> HIGH/CRITICAL risk (liveness check enabled); otherwise LOW/NONE risk."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains location and event', function () {",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json).to.have.property('location');",
                  "  pm.expect(json).to.have.property('event');",
                  "  pm.expect(json.location).to.have.property('userId');",
                  "  pm.expect(json.location).to.have.property('latitude');",
                  "  pm.expect(json.location).to.have.property('longitude');",
                  "  pm.expect(json.location).to.have.property('updatedAt');",
                  "  pm.expect(json.event).to.have.property('id');",
                  "  pm.expect(json.event).to.have.property('userId');",
                  "  pm.expect(json.event).to.have.property('latitude');",
                  "  pm.expect(json.event).to.have.property('longitude');",
                  "  pm.expect(json.event).to.have.property('detectedAt');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User risks",
      "item": [
        {
          "name": "Set liveness check",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user-risks/HIGH_RISK_AREA/liveness-check",
              "host": ["{{baseUrl}}"],
              "path": ["user-risks", "HIGH_RISK_AREA", "liveness-check"]
            },
            "description": "PATCH /api/user-risks/:riskType/liveness-check. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Body: { enabled: boolean }. Upserts a UserRisk row with livenessCheckEnabled for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response has userId, riskType and livenessCheckEnabled', function () {",
                  "  pm.expect(json).to.have.property('userId');",
                  "  pm.expect(json).to.have.property('riskType');",
                  "  pm.expect(json).to.have.property('livenessCheckEnabled');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get liveness check statuses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user-risks/liveness-check",
              "host": ["{{baseUrl}}"],
              "path": ["user-risks", "liveness-check"]
            },
            "description": "GET /api/user-risks/liveness-check. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Returns an array of { riskType, livenessCheckEnabled } for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Respond to liveness check",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{baseUrl}}/user-risks/HIGH_RISK_AREA/liveness-check/respond",
              "host": ["{{baseUrl}}"],
              "path": [
                "user-risks",
                "HIGH_RISK_AREA",
                "liveness-check",
                "respond"
              ]
            },
            "description": "POST /api/user-risks/:riskType/liveness-check/respond. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard) and a boolean isOkay body field. An affirmative response clears the risk level to NONE; a negative response preserves the current risk state, appends a UserRiskEvent, and immediately queues guardian notifications. Returns { risk, event }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains risk and event', function () {",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json).to.have.property('risk');",
                  "  pm.expect(json).to.have.property('event');",
                  "  pm.expect(json.risk.riskLevel).to.eql('NONE');",
                  "  pm.expect(json.event.isOkay).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Accidents",
      "item": [
        {
          "name": "Record accident event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"FALL_DETECTED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accidents",
              "host": ["{{baseUrl}}"],
              "path": ["accidents"]
            },
            "description": "POST /api/accidents. Requires Authorization: Bearer {{accessToken}} (JwtAuthGuard). Body: { eventType: 'FALL_DETECTED' | 'MOVEMENT', detectedAt?: ISO string }. Records a fall or movement signal for the authenticated user. If detectedAt is omitted, the server uses the current time."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response contains id, userId, eventType and detectedAt', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('userId');",
                  "  pm.expect(json).to.have.property('eventType');",
                  "  pm.expect(json).to.have.property('detectedAt');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
