DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhu_server?schema=public"
REDIS_URL="redis://localhost:6379"
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="zhu-server"
KAFKA_USER_EVENTS_TOPIC="user-events.v1"
KAFKA_USER_EVENTS_PARTITIONS=12

# Outbox dispatcher interval in milliseconds.
OUTBOX_DISPATCH_INTERVAL_MS=1000

# Location consumer worker. Set to true/1/yes to subscribe to Kafka.
KAFKA_LOCATION_CONSUMER_ENABLED="false"
KAFKA_LOCATION_CONSUMER_GROUP="location-worker"

# Android Firebase Cloud Messaging. ADC reads credentials from this file when enabled.
FCM_ENABLED="false"
FCM_TEST_SEND_ENABLED="false"
FIREBASE_PROJECT_ID=""
GOOGLE_APPLICATION_CREDENTIALS=""

# Liveness check worker. Runs every X milliseconds; only users whose HIGH/CRITICAL
# risk has persisted for at least the risk-age threshold are selected.
LIVENESS_CHECK_INTERVAL_MS=60000
LIVENESS_CHECK_RISK_AGE_SECONDS=60

# Guardian notifications. Negative liveness responses enqueue an immediate alert;
# timeout alerts run periodically after an unanswered liveness check.
GUARDIAN_NOTIFICATION_ENABLED="false"
GUARDIAN_NOTIFICATION_INTERVAL_MS=60000
GUARDIAN_NOTIFICATION_RISK_AGE_SECONDS=60
GUARDIAN_NOTIFICATION_COOLDOWN_SECONDS=300

# Earthquake poller. Set to true/1/yes to poll BMKG for recent earthquakes.
EARTHQUAKE_POLLING_ENABLED="false"
EARTHQUAKE_POLLING_INTERVAL_MS=300000
EARTHQUAKE_AFFECTED_RADIUS_KM=200
BMKG_GEMPATERKINI_URL="https://data.bmkg.go.id/DataMKG/TEWS/gempaterkini.json"

# Accident monitor. Set to true/1/yes to monitor fall detection and movement events.
ACCIDENT_MONITOR_ENABLED="false"
ACCIDENT_MONITOR_INTERVAL_MS=300000
ACCIDENT_NO_MOVEMENT_HOURS=6

JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
PORT=3000

# Used by docker-compose.production.yml on the VPS. The production DATABASE_URL
# must use POSTGRES_HOST_PORT and the same URL-encoded POSTGRES_PASSWORD.
POSTGRES_PASSWORD="replace-with-a-strong-random-password"
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6379
KAFKA_HOST_PORT=9092
