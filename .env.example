DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhu_server?schema=public"
REDIS_URL="redis://localhost:6379"
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="zhu-server"
KAFKA_USER_EVENTS_TOPIC="user-events.v1"
KAFKA_USER_EVENTS_PARTITIONS=12
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
PORT=3000

# Used by docker-compose.production.yml on the VPS. The production DATABASE_URL
# must use POSTGRES_HOST_PORT and the same URL-encoded POSTGRES_PASSWORD.
POSTGRES_PASSWORD="replace-with-a-strong-random-password"
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6379
KAFKA_HOST_PORT=9092
